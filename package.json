{
  "name": "tuffgal",
  "version": "0.0.0",
  "description": "JSON-driven visual regression for web apps.",
  "license": "MIT",
  "author": "Nick Schneble",
  "homepage": "https://github.com/nschneble/tuffgal",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nschneble/tuffgal.git"
  },
  "scripts": {
    "build": "echo \"no build step until v0.1.0-alpha\" && exit 0",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "install:browsers": "playwright install chromium",
    "lint": "eslint \"src/**/*.ts\" \"bin/**/*.ts\" --max-warnings=0",
    "test": "echo \"no tests yet\" && exit 0",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "tuffgal": "./bin/tuffgal.ts"
  },
  "bugs": {
    "url": "https://github.com/nschneble/tuffgal/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "bin/",
    "LICENSE",
    "README.md",
    "src/"
  ],
  "keywords": [
    "playwright",
    "screenshots",
    "snapshot-testing",
    "ssim",
    "testing",
    "ui-testing",
    "visual-regression"
  ],
  "main": "./src/index.ts",
  "type": "module",
  "types": "./src/index.ts",
  "dependencies": {
    "monocart-coverage-reports": "^2.12.0",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.49.0",
    "pngjs": "^7.0.0",
    "ssim.js": "^3.5.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.7.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.49.0"
  }
}
