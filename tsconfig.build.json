{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rewriteRelativeImportExtensions": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "dist",
    "examples",
    "node_modules",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
